# .envrc — loaded automatically by direnv when you enter this directory.
# https://direnv.net
#
# Exports GNO_CLUSTER_ROOT so helper scripts and the completion rc hook
# (below) can find the project regardless of which subdir you're in.
#
# IMPORTANT — tab completion caveat:
#   direnv propagates environment variables to the parent shell, but NOT
#   shell functions. Tab-completion is a shell function, so sourcing it here
#   has no effect on your interactive shell. To get completion activated
#   automatically when you cd in (and deactivated when you leave), add the
#   snippet below to your ~/.bashrc or ~/.zshrc ONCE. After that, this
#   .envrc + the hook give you fully automatic per-directory completion.
#
# zsh snippet (~/.zshrc):
#
#     autoload -Uz add-zsh-hook
#     _gno_cluster_load_completion() {
#         if [ -n "$GNO_CLUSTER_ROOT" ] \
#                 && [ -f "$GNO_CLUSTER_ROOT/completions/gno-cluster.zsh" ]; then
#             source "$GNO_CLUSTER_ROOT/completions/gno-cluster.zsh"
#         fi
#     }
#     add-zsh-hook chpwd _gno_cluster_load_completion
#     _gno_cluster_load_completion   # also run in the current shell
#
# bash snippet (~/.bashrc):
#
#     _gno_cluster_load_completion() {
#         if [ -n "$GNO_CLUSTER_ROOT" ] \
#                 && [ -f "$GNO_CLUSTER_ROOT/completions/gno-cluster.bash" ]; then
#             source "$GNO_CLUSTER_ROOT/completions/gno-cluster.bash"
#         fi
#     }
#     PROMPT_COMMAND="_gno_cluster_load_completion${PROMPT_COMMAND:+; }${PROMPT_COMMAND:-}"
#
# Without the rc hook: fall back to `source completions/gno-cluster.zsh`
# (or .bash) manually when you want completion in the current shell.

export GNO_CLUSTER_ROOT="$PWD"
