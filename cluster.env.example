# Git tag/branch of gno to build
GNO_VERSION=master
# GitHub repo for gno (owner/repo format)
GNO_REPO=gnolang/gno

# Git tag/branch of watchtower/sentinel to build
WATCHTOWER_VERSION=main
# GitHub repo for watchtower/sentinel (owner/repo format)
WATCHTOWER_REPO=aeddi/gno-watchtower

# Number of nodes in the cluster
NUM_NODES=4

# Network topology: mesh, star, ring
TOPOLOGY=mesh

# Host RPC port for node-1 (increments per node: node-2 = base+1, etc.)
GNOLAND_RPC_PORT_BASE=26657

# Host P2P port for node-1 (increments per node: node-2 = base+1, etc.)
# Must not overlap with RPC range: ensure P2P_BASE >= RPC_BASE + NUM_NODES
GNOLAND_P2P_PORT_BASE=26670

# Host port for Grafana UI
GRAFANA_PORT=3000

# Host port for VictoriaMetrics HTTP API
VICTORIA_METRICS_PORT=8428

# Host port for Loki HTTP API
LOKI_PORT=3100
