# gnoland node config overrides (optional).
# Applied to gnoland-data/config/config.toml via 'gnoland config set' on each
# container start, BEFORE the system-hardcoded overrides listed below.
# Format: key = value (one per line; # for comments; blank lines ignored)

# ---- System-hardcoded keys (overridden by the system, cannot be customized)
# p2p.laddr            = "tcp://0.0.0.0:26656"    # in-container P2P bind
# rpc.laddr            = "tcp://0.0.0.0:26657"    # in-container RPC bind
# p2p.persistent_peers = <derived from TOPOLOGY>  # auto-wired per node
#
# Telemetry keys (pinned by the entrypoint; cannot be customized here):
# telemetry.metrics_enabled     = true                 # OTLP export to sentinel-N:4318 (HTTP)
# telemetry.traces_enabled      = false                # watchtower has no trace backend yet
# telemetry.exporter_endpoint   = "http://sentinel-<N>:4318"
# telemetry.service_name        = "gno-cluster"
# telemetry.service_instance_id = "node-<N>"

# ---- Global Overrides (applied to all nodes)
# Lines before the first [section] header apply to every node.

# Recommended settings for a validator node
consensus.peer_gossip_sleep_duration = "10ms"
consensus.timeout_commit = "3s"
mempool.size = 10000
p2p.flush_throttle_timeout = "10ms"
p2p.max_num_outbound_peers = 40

# ---- Per-Node Overrides
# Section headers target specific nodes. Everything under a header
# belongs to that section until the next header appears.
# Global section is top-only — cannot be re-entered after a [section].
# Last-match wins: if the same key is set for a node in multiple
# sections, the last value in file order takes effect.

# [node-1]
# consensus.timeout_commit = "5s"

# [node-2, node-3]
# mempool.size = 5000
